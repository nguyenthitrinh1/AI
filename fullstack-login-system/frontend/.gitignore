# ============================================================
# Frontend .gitignore  (Next.js / Node)
# ============================================================

# ── Secrets ────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ── Dependencies ────────────────────────────────────────────
node_modules/

# ── Next.js build output ────────────────────────────────────
.next/
out/
dist/
build/

# ── Next.js / Turbopack caches ──────────────────────────────
.turbo/
.swc/
*.tsbuildinfo

# ── next-env.d.ts is auto-generated ────────────────────────
next-env.d.ts

# ── npm / yarn / pnpm debug logs ───────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ── Test outputs ────────────────────────────────────────────
coverage/
.coverage
test-results/
playwright-report/
playwright/.cache/

# ── OS & editor noise ──────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp